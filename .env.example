# Survey Analysis Agent - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Provider selection: "bedrock" (default) or "openai"
LLM_PROVIDER=bedrock

# Enable LLM-generated summaries (default: false)
LLM_SUMMARY_ENABLED=false

# =============================================================================
# Amazon Bedrock Configuration (when LLM_PROVIDER=bedrock)
# =============================================================================

# AWS credentials (required for Bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Or use AWS CLI profile instead of explicit credentials
# AWS_PROFILE=your-profile
# AWS_REGION=us-east-1

# Bedrock model ID (default: us.anthropic.claude-sonnet-4-6)
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6

# =============================================================================
# OpenAI Configuration (when LLM_PROVIDER=openai)
# =============================================================================

# OpenAI API key (required when using OpenAI provider)
OPENAI_API_KEY=

# OpenAI model ID (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
